# ─── Azure DevOps ────────────────────────────────────────────────────────────
# Your Azure DevOps organization name (from dev.azure.com/<org>)
AZURE_DEVOPS_ORG=your-org-name

# The project and repository name inside Azure DevOps
AZURE_DEVOPS_PROJECT=your-project-name
AZURE_DEVOPS_REPO=your-repo-name

# ─── Azure DevOps Authentication (Service Principal - Recommended) ───
# Obtain these by creating an App Registration in Microsoft Entra ID
AZURE_TENANT_ID=your-tenant-id-here
AZURE_CLIENT_ID=your-client-id-here
AZURE_CLIENT_SECRET=your-secret-value-here

# ─── Azure DevOps Authentication (Personal Access Token - Legacy Fallback) ───
# If you don't use a Service Principal, you can use a PAT instead.
# Generate at: https://dev.azure.com/<org>/_usersSettings/tokens
AZURE_DEVOPS_PAT=your-pat-here

# Shared secret configured in your Azure DevOps Service Hook for webhook validation
AZURE_DEVOPS_WEBHOOK_SECRET=your-webhook-secret

# ─── AWS Bedrock ─────────────────────────────────────────────────────────────
# AWS region where Bedrock is available (e.g. us-east-1, us-west-2)
AWS_REGION=us-east-1

# Bedrock model ID to use for all LLM review agents
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# AWS credentials — leave blank if using an IAM Role or AWS CLI profile
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# ─── App ─────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── Paths ───────────────────────────────────────────────────────────────────
# Absolute path to the local clone of the repo being reviewed
# The agent checks out branches and runs Aider here
DEMO_REPO_PATH=/absolute/path/to/your/demo-repo

# Path to store ChromaDB vector embeddings (RAG guidelines index)
CHROMA_DB_PATH=./chroma_db

# Path to the SQLite job queue database
SQLITE_DB_PATH=./review_agent.db

# ─── Aider ───────────────────────────────────────────────────────────────────
# Maximum number of times the agent will retry fixing a CI failure before giving up
AIDER_MAX_CI_RETRIES=4

# Minimum confidence score (0.0 to 1.0) for a finding to be auto-fixed by Aider
# Findings below this threshold are reported but not automatically changed
MIN_FIX_CONFIDENCE=0.80